function doGet(e) {
  const tpl = HtmlService.createTemplateFromFile('v2_index');
  tpl.userEmail = Session.getActiveUser().getEmail();
  tpl.versao = '2.0.4-pro-favicon-ico';
  return tpl.evaluate()
    .setTitle('FinControl 360 Pro°')
    .setFaviconUrl('https://diogolejardam-commits.github.io/fincontrol360/favicon.ico')
    .addMetaTag('viewport', 'width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no')
    .setXFrameOptionsMode(HtmlService.XFrameOptionsMode.ALLOWALL);
}

function include(filename) {
  return HtmlService.createHtmlOutputFromFile(filename).getContent();
}

function instalarFinControlV2() {
  const inicio = new Date();
  Logger.log('▶ Iniciando instalação FINAL...');
  const scriptId = ScriptApp.getScriptId();
  const testeUrl = 'https://script.googleapis.com/v1/projects/' + scriptId + '/content';
  const testResp = UrlFetchApp.fetch(testeUrl, {
    method: 'get',
    headers: { Authorization: 'Bearer ' + ScriptApp.getOAuthToken() },
    muteHttpExceptions: true
  });
  if (testResp.getResponseCode() !== 200) {
    Logger.log('✖ Apps Script API erro: ' + testResp.getResponseCode());
    return;
  }
  Logger.log('✓ API OK');
  const arquivos = _fcArquivos_();
  let criados = 0, erros = 0;
  const erroDet = [];
  for (const arq of arquivos) {
    try {
      _fcCriarArq_(scriptId, arq.nome, arq.tipo, arq.conteudo);
      Logger.log('✓ ' + arq.nome);
      criados++;
    } catch (e) {
      Logger.log('✖ ' + arq.nome + ': ' + e.message);
      erroDet.push(arq.nome + ': ' + e.message);
      erros++;
    }
  }
  const tempo = ((new Date() - inicio) / 1000).toFixed(1);
  const msg = '═══════════════════════════════════════\n' +
    (erros === 0 ? '✅ INSTALADO!' : '⚠️ COM ERROS') + ' em ' + tempo + 's\n' +
    'Arquivos: ' + criados + '/' + arquivos.length + '\n' +
    'Erros: ' + erros + '\n' +
    (erros > 0 ? '\n' + erroDet.join('\n') : '') + '\n' +
    '\nPRÓXIMO PASSO:\n1. Implantar → Gerenciar → ✏️ → Nova versão → Implantar\n2. Cmd+Shift+R no Web App';
  Logger.log(msg);
}

function _fcCriarArq_(scriptId, nome, tipo, conteudo) {
  const token = ScriptApp.getOAuthToken();
  const url = 'https://script.googleapis.com/v1/projects/' + scriptId + '/content';
  const respGet = UrlFetchApp.fetch(url, {
    method: 'get',
    headers: { Authorization: 'Bearer ' + token },
    muteHttpExceptions: true
  });
  if (respGet.getResponseCode() !== 200) {
    throw new Error('GET ' + respGet.getResponseCode() + ': ' + respGet.getContentText().substring(0, 200));
  }
  const projeto = JSON.parse(respGet.getContentText());
  const files = projeto.files || [];
  const idx = files.findIndex(f => f.name === nome);
  if (idx >= 0) files.splice(idx, 1);
  files.push({
    name: nome,
    type: tipo === 'html' ? 'HTML' : 'SERVER_JS',
    source: conteudo
  });
  const respPut = UrlFetchApp.fetch(url, {
    method: 'put',
    contentType: 'application/json',
    headers: { Authorization: 'Bearer ' + token },
    payload: JSON.stringify({ files: files }),
    muteHttpExceptions: true
  });
  if (respPut.getResponseCode() !== 200) {
    throw new Error('PUT ' + respPut.getResponseCode() + ': ' + respPut.getContentText().substring(0, 300));
  }
}

