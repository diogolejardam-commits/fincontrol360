/**
 * DIAGNÓSTICO CIRÚRGICO — Cole no FIM do Código.gs e execute "diagCAP_v2"
 * Não mexe em nada, só mostra o que está na planilha.
 */

function diagCAP_v2() {
  const ID = '1EGeK7F7we_hZxae73OBxWb2RHs22whHB5UvbGpQMgJU';
  const sh = SpreadsheetApp.openById(ID).getSheetByName('CONTAS A PAGAR');
  if (!sh) { Logger.log('✖ Aba CONTAS A PAGAR não encontrada'); return; }

  const lastRow = sh.getLastRow();
  const lastCol = sh.getLastColumn();

  const headers = sh.getRange(1, 1, 1, lastCol).getValues()[0].map(h => String(h||'').trim());
  Logger.log('═══════════════════════════════════════════════');
  Logger.log('CABEÇALHOS (linha 1):');
  headers.forEach((h, i) => {
    const letra = String.fromCharCode(65 + i);
    Logger.log('  Col ' + letra + ' (' + (i+1) + ') = "' + h + '"');
  });

  const idxParcela = headers.indexOf('Parcela');
  const idxStatus = headers.indexOf('Status');
  const idxDesc = headers.indexOf('Descrição');
  const idxVenc = headers.indexOf('Vencimento');

  Logger.log('');
  Logger.log('═══════════════════════════════════════════════');
  Logger.log('ÍNDICES IMPORTANTES:');
  Logger.log('  Parcela → coluna ' + (idxParcela+1) + ' (' + (idxParcela>=0?String.fromCharCode(65+idxParcela):'NÃO ENCONTRADO') + ')');
  Logger.log('  Status → coluna ' + (idxStatus+1) + ' (' + (idxStatus>=0?String.fromCharCode(65+idxStatus):'NÃO ENCONTRADO') + ')');

  if (lastRow < 2) { Logger.log('Sem dados.'); return; }

  Logger.log('');
  Logger.log('═══════════════════════════════════════════════');
  Logger.log('DADOS DAS CONTAS (' + (lastRow-1) + ' linha(s)):');

  const dados = sh.getRange(2, 1, lastRow-1, lastCol).getValues();
  const formulas = sh.getRange(2, 1, lastRow-1, lastCol).getFormulas();

  for (let i = 0; i < dados.length; i++) {
    const numLinha = i + 2;
    const desc = idxDesc >= 0 ? dados[i][idxDesc] : '?';
    const venc = idxVenc >= 0 ? dados[i][idxVenc] : '?';
    const parcela = idxParcela >= 0 ? dados[i][idxParcela] : '?';
    const status = idxStatus >= 0 ? dados[i][idxStatus] : '?';
    const parcelaFormula = idxParcela >= 0 ? formulas[i][idxParcela] : '';

    Logger.log('');
    Logger.log('━━━ LINHA ' + numLinha + ' ━━━');
    Logger.log('  Descrição: ' + desc);
    Logger.log('  Vencimento: ' + (venc instanceof Date ? venc.toLocaleDateString('pt-BR') : venc));
    Logger.log('  Status: "' + status + '" (tipo: ' + typeof status + ')');
    Logger.log('  Parcela: "' + parcela + '" (tipo: ' + typeof parcela + ')');
    if (parcelaFormula) Logger.log('  Parcela TEM FÓRMULA: ' + parcelaFormula);

    const s = String(parcela||'').trim();
    const m = s.match(/^(\d+)\/(\d+)$/);
    if (m) {
      Logger.log('  ✓ Parser OK: atual=' + m[1] + ' total=' + m[2]);
    } else if (s === '') {
      Logger.log('  ⚠ Parcela VAZIA → será tratada como 1/1 (à vista)');
    } else {
      Logger.log('  ✖ Parser FALHOU para formato: "' + s + '"');
    }
  }

  Logger.log('');
  Logger.log('═══════════════════════════════════════════════');
  Logger.log('FIM DO DIAGNÓSTICO');
}

function _descobrirPlanilhaVinculada() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  if (ss) {
    Logger.log('Nome: ' + ss.getName());
    Logger.log('ID: ' + ss.getId());
    Logger.log('URL: ' + ss.getUrl());
  } else {
    Logger.log('SEM planilha vinculada (projeto standalone)');
  }
}
