  "  if (p.dataLanc) set('Data Lançamento', fc2_isoParaData_(p.dataLanc));",
  "  if (p.venc) set('Vencimento', fc2_isoParaData_(p.venc));",
  "  set('Descrição', p.desc||'');",
  "  if (p.parcela !== undefined) set('Parcela', p.parcela);",
  "  set('Conta', p.banco || p.conta || '');",
  "  set('Categoria', p.categoria||'');",
  "  set('Tipo', p.tipo||'Despesa');",
  "  set('Valor', Number(p.valor)||0);",
  "  set('Status', p.status||'🕛 Em aberto');",
  "  if (p.dataPgto) set('Data Pagamento', fc2_isoParaData_(p.dataPgto));",
  "  else if (p.dataPgto===null||p.dataPgto==='') set('Data Pagamento','');",
  "  set('Origem', p.origem||'WebApp');",
  "  set('Observação', p.observacao||'');",
  "}",
  "function fc2_lancExcluir_(linha) {",
  "  if (!linha || linha < 2) throw new Error('Linha inválida');",
  "  const sh = fc2_aba_(FC2_CONFIG.ABAS.LANC);",
  "  sh.deleteRow(linha);",
  "  fc2_cacheLimparTudo_();",
  "  return { acao:'excluido', linha:linha };",
  "}",
  "function fc2_lancPagar_(linha, dataPgto) {",
  "  if (!linha || linha < 2) throw new Error('Linha inválida');",
  "  const sh = fc2_aba_(FC2_CONFIG.ABAS.LANC);",
  "  const mapa = fc2_resolverMapaColunas_(sh);",
  "  const d = dataPgto ? fc2_isoParaData_(dataPgto) : new Date();",
  "  sh.getRange(linha, mapa['Status']).setValue('✅ Pago');",
  "  sh.getRange(linha, mapa['Data Pagamento']).setValue(d);",
  "  fc2_cacheLimparTudo_();",
  "  return { acao:'pago', linha:linha };",
  "}",
  "function fc2_lancEstornar_(linha) {",
  "  if (!linha || linha < 2) throw new Error('Linha inválida');",
  "  const sh = fc2_aba_(FC2_CONFIG.ABAS.LANC);",
