function _fc_00config_() {
  return [
  "const FC2_PLANILHA_ID = '1EGeK7F7we_hZxae73OBxWb2RHs22whHB5UvbGpQMgJU';",
  "const FC2_CONFIG = {",
  "  VERSAO: '2.0.4-pro-favicon-ico',",
  "  ABAS: {",
  "    DASH: 'Dashboard', LANC: 'Lançamentos', CAP: 'CONTAS A PAGAR',",
  "    CRED: 'Crédito', BOL: 'BOLETOS_DOCUMENTOS', CFG: 'CONFIG_IMPORTACAO',",
  "    LOG: 'LOG_OCR_BOLETOS', LOG_ADMIN: 'LOG_ADMIN'",
  "  },",
  "  CACHE_TTL: { DASHBOARD: 60, CADASTROS: 21600, SESSAO: 1800 },",
  "  STATUS_PAGOS: ['✅ Pago','✅ Quitado']",
  "};",
  "function fc2_ss_() { return SpreadsheetApp.openById(FC2_PLANILHA_ID); }",
  "function fc2_aba_(nome) {",
  "  const sh = fc2_ss_().getSheetByName(nome);",
  "  if (!sh) throw new Error('Aba \"' + nome + '\" não encontrada.');",
  "  return sh;",
  "}",
  "function fc2_resolverMapaColunas_(sh) {",
  "  const lastCol = sh.getLastColumn();",
  "  if (lastCol < 1) return {};",
  "  const headers = sh.getRange(1, 1, 1, lastCol).getValues()[0];",
  "  const mapa = {};",
  "  headers.forEach(function(h, i) {",
  "    const k = String(h || '').trim();",
  "    if (k && !mapa[k]) mapa[k] = i + 1;",
  "  });",
  "  return mapa;",
  "}",
  "function _fcSafeStr_(v) {",
  "  if (v === null || v === undefined) return '';",
  "  if (typeof v === 'object') {",
  "    if (v.valueType) return '';",
  "    if (v instanceof Date) return v.toISOString();",
  "    try { return JSON.stringify(v); } catch(e) { return ''; }",
  "  }",
  "  return String(v);",
  "}",
  "function fc2_parseNumero_(v) {",
  "  if (v === null || v === undefined || v === '') return 0;",
  "  if (typeof v === 'number') return v;",
  "  if (typeof v === 'object') return 0;",
  "  const s = String(v).replace(/R\\$\\s?/g, '').replace(/\\./g, '').replace(',', '.').trim();",
  "  const n = parseFloat(s);",
  "  return isNaN(n) ? 0 : n;",
  "}",
  "function fc2_parseData_(v) {",
  "  if (!v) return null;",
  "  if (v instanceof Date) return v;",
  "  if (typeof v === 'string') {",
  "    const m = v.match(/^(\\d{1,2})\\/(\\d{1,2})\\/(\\d{4})/);",
  "    if (m) return new Date(parseInt(m[3]), parseInt(m[2])-1, parseInt(m[1]));",
  "    const d = new Date(v);",
  "    return isNaN(d.getTime()) ? null : d;",
  "  }",
  "  return null;",
  "}",
  "function fc2_dataParaISO_(v) { const d = fc2_parseData_(v); return d ? d.toISOString() : ''; }",
  "function fc2_isoParaData_(iso) {",
  "  if (!iso) return '';",
  "  if (iso instanceof Date) return iso;",
  "  const d = new Date(iso);",
  "  if (isNaN(d.getTime())) return '';",
  "  if (typeof iso === 'string' && /^\\d{4}-\\d{2}-\\d{2}$/.test(iso)) {",
  "    return new Date(d.getFullYear(), d.getMonth(), d.getDate(), 12, 0, 0);",
  "  }",
  "  return d;",
  "}",
  "function fc2_cacheGet_(k) {",
  "  try { const c = CacheService.getScriptCache().get(k); return c ? JSON.parse(c) : null; }",
  "  catch(e) { return null; }",
  "}",
  "function fc2_cacheSet_(k, v, ttl) {",
  "  try { CacheService.getScriptCache().put(k, JSON.stringify(v), ttl || 60); } catch(e) {}",
  "}",
  "function fc2_cacheDel_(k) { try { CacheService.getScriptCache().remove(k); } catch(e) {} }",
  "function fc2_cacheLimparTudo_() {",
  "  try { CacheService.getScriptCache().removeAll(['dashboard:atual','cad:bancos','cad:categorias','cad:cartoes']); } catch(e) {}",
  "}",
  "function fc2_logAdmin_(acao, status, detalhes) {",
  "  try {",
  "    const sh = fc2_ss_().getSheetByName('LOG_ADMIN');",
  "    if (!sh) return;",
  "    sh.appendRow([new Date(), Session.getActiveUser().getEmail(), acao, status, detalhes || '']);",
  "  } catch(e) {}",
  "}",
  "function _fcGerarId_() {",
  "  const d = new Date();",
  "  return Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyyMMddHHmmss') + '-' +",
  "         Math.random().toString(36).substring(2,8).toUpperCase();",
  "}"
].join("\n"); }

function _fc_20svcdashboard_() {
  return [
  "function fc2_svcDashboardKPIs_(mesRef) {",
  "  const t0 = Date.now();",
  "  const ref = mesRef ? new Date(mesRef) : new Date();",
  "  const m = ref.getMonth(); const a = ref.getFullYear();",
  "  function noMes(d) { return d && d.getMonth() === m && d.getFullYear() === a; }",
  "  function pago(s) { return s === '✅ Pago' || s === '✅ Quitado'; }",
  "  const out = { mes: m+1, ano: a, entradas:0, saidas:0, saldo:0, abertosCAP:0, pagosCAP:0, abertosCred:0, atrasados:0 };",
  "  try {",
  "    const sh = fc2_aba_(FC2_CONFIG.ABAS.LANC);",
  "    const lr = sh.getLastRow();",
  "    if (lr >= 2) {",
  "      const mapa = fc2_resolverMapaColunas_(sh);",
  "      const dados = sh.getRange(2,1,lr-1,sh.getLastColumn()).getValues();",
  "      const cVenc = mapa['Vencimento'], cTipo = mapa['Tipo'], cValor = mapa['Valor'], cStatus = mapa['Status'], cDP = mapa['Data Pagamento'];",
  "      for (let i=0; i<dados.length; i++) {",
  "        const r = dados[i];",
  "        if (!r[cVenc-1]) continue;",
  "        const status = _fcSafeStr_(r[cStatus-1]);",
  "        const dRef = pago(status) ? fc2_parseData_(r[cDP-1]) || fc2_parseData_(r[cVenc-1]) : fc2_parseData_(r[cVenc-1]);",
  "        if (!noMes(dRef)) continue;",
  "        const valor = fc2_parseNumero_(r[cValor-1]);",
  "        const tipo = _fcSafeStr_(r[cTipo-1]);",
  "        if (tipo === 'Entrada' || tipo === 'Receita') out.entradas += valor;",
  "        else out.saidas += valor;",
  "      }",
  "    }",
  "  } catch(e) {}",
  "  try {",
  "    const sh = fc2_aba_(FC2_CONFIG.ABAS.CAP);",
  "    const lr = sh.getLastRow();",
  "    if (lr >= 2) {",
  "      const mapa = fc2_resolverMapaColunas_(sh);",
  "      const dados = sh.getRange(2,1,lr-1,sh.getLastColumn()).getValues();",
  "      const cVenc = mapa['Vencimento'], cValor = mapa['Valor'], cStatus = mapa['Status'];",
  "      const hoje = new Date(); hoje.setHours(0,0,0,0);",
  "      for (let i=0; i<dados.length; i++) {",
  "        const r = dados[i]; if (!r[cVenc-1]) continue;",
  "        const d = fc2_parseData_(r[cVenc-1]);",
  "        const status = _fcSafeStr_(r[cStatus-1]);",
  "        const valor = fc2_parseNumero_(r[cValor-1]);",
  "        if (noMes(d)) {",
  "          if (pago(status)) out.pagosCAP += valor;",
  "          else out.abertosCAP += valor;",
  "        }",
  "        if (!pago(status) && d && d < hoje) out.atrasados += valor;",
  "      }",
  "    }",
  "  } catch(e) {}",
  "  try {",
  "    const sh = fc2_aba_(FC2_CONFIG.ABAS.CRED);",
  "    const lr = sh.getLastRow();",
  "    if (lr >= 2) {",
  "      const mapa = fc2_resolverMapaColunas_(sh);",
  "      const dados = sh.getRange(2,1,lr-1,sh.getLastColumn()).getValues();",
  "      const cVenc = mapa['Vencimento'], cValor = mapa['Valor Parcela'], cStatus = mapa['Status'];",
  "      for (let i=0; i<dados.length; i++) {",
  "        const r = dados[i]; if (!r[cVenc-1]) continue;",
  "        if (!noMes(fc2_parseData_(r[cVenc-1]))) continue;",
  "        if (pago(_fcSafeStr_(r[cStatus-1]))) continue;",
  "        out.abertosCred += fc2_parseNumero_(r[cValor-1]);",
  "      }",
  "    }",
  "  } catch(e) {}",
  "  out.saldo = out.entradas - out.saidas;",
  "  out.took = Date.now() - t0;",
  "  return out;",
  "}"
].join("\n"); }

function _fc_11repolancamentos_() {
  return [
  "function fc2_lancListar_(filtros) {",
  "  const t0 = Date.now(); filtros = filtros || {};",
  "  const sh = fc2_aba_(FC2_CONFIG.ABAS.LANC);",
  "  const lastRow = sh.getLastRow(); const lastCol = sh.getLastColumn();",
  "  if (lastRow < 2) return { items: [], total: 0, took: Date.now()-t0 };",
  "  const dados = sh.getRange(2,1,lastRow-1,lastCol).getValues();",
  "  const colunas = sh.getRange(1,1,1,lastCol).getValues()[0].map(function(h){return String(h||'').trim();});",
  "  const idxDesc = colunas.indexOf('Descrição');",
  "  const idxValor = colunas.indexOf('Valor');",
  "  const items = [];",
  "  for (let i = 0; i < dados.length; i++) {",
  "    const r = {};",
  "    for (let j = 0; j < colunas.length; j++) { r[colunas[j]] = dados[i][j]; }",
  "    const temDesc = idxDesc >= 0 && _fcSafeStr_(dados[i][idxDesc]).trim() !== '';",
  "    const valor = idxValor >= 0 ? fc2_parseNumero_(dados[i][idxValor]) : 0;",
  "    if (!temDesc && valor === 0) continue;",
  "    r._linha = i + 2; items.push(r);",
  "  }",
  "  let f = items;",
  "  if (filtros.mesRef) { const ref = new Date(filtros.mesRef); const m = ref.getMonth(), a = ref.getFullYear();",
  "    f = f.filter(function(r){ const d = fc2_parseData_(r['Vencimento']); return d && d.getMonth()===m && d.getFullYear()===a; });",
  "  }",
  "  if (filtros.tipo) {",
  "    const tipoNorm = (filtros.tipo === 'Saída' || filtros.tipo === 'Despesa') ? ['Saída','Despesa'] : ((filtros.tipo === 'Entrada' || filtros.tipo === 'Receita') ? ['Entrada','Receita'] : [filtros.tipo]);",
  "    f = f.filter(function(r){ return tipoNorm.indexOf(_fcSafeStr_(r['Tipo']))!==-1; });",
  "  }",
  "  if (filtros.status) f = f.filter(function(r){ return _fcSafeStr_(r['Status'])===filtros.status; });",
  "  if (filtros.busca) { const q = filtros.busca.toLowerCase();",
  "    f = f.filter(function(r){",
  "      return _fcSafeStr_(r['Descrição']).toLowerCase().indexOf(q)!==-1 ||",
  "             _fcSafeStr_(r['Categoria']).toLowerCase().indexOf(q)!==-1 ||",
  "             _fcSafeStr_(r['Banco']).toLowerCase().indexOf(q)!==-1 ||",
  "             _fcSafeStr_(r['Conta']).toLowerCase().indexOf(q)!==-1;",
  "    });",
  "  }",
  "  f.sort(function(a,b){ const da=fc2_parseData_(a['Vencimento']),db=fc2_parseData_(b['Vencimento']);",
  "    if(!da&&!db)return 0; if(!da)return 1; if(!db)return -1; return db-da; });",
  "  const total = f.length; const limit = filtros.limit||50; const offset = filtros.offset||0;",
  "  const pagina = f.slice(offset, offset+limit);",
  "  const out = pagina.map(function(r){",
  "    const bancoStr = _fcSafeStr_(r['Banco']);",
  "    const contaStr = _fcSafeStr_(r['Conta']);",
  "    const banco = bancoStr || contaStr;",
  "    return {",
  "      _linha: r._linha,",
  "      id: _fcSafeStr_(r['ID']),",
  "      dataLanc: fc2_dataParaISO_(r['Data Lançamento']),",
  "      venc: fc2_dataParaISO_(r['Vencimento']),",
  "      desc: _fcSafeStr_(r['Descrição']),",
  "      parcela: _fcSafeStr_(r['Parcela']),",
  "      banco: banco,",
  "      conta: contaStr,",
  "      categoria: _fcSafeStr_(r['Categoria']),",
  "      tipo: _fcSafeStr_(r['Tipo']),",
  "      valor: fc2_parseNumero_(r['Valor']),",
  "      status: _fcSafeStr_(r['Status']),",
  "      dataPgto: fc2_dataParaISO_(r['Data Pagamento']),",
  "      origem: _fcSafeStr_(r['Origem']),",
  "      observacao: _fcSafeStr_(r['Observação'])",
  "    };",
  "  });",
  "  return { items: out, total: total, took: Date.now()-t0 };",
  "}",
  "function fc2_lancSalvar_(p) {",
  "  if (!p) throw new Error('Payload vazio');",
  "  if (!p.desc) throw new Error('Descrição é obrigatória');",
  "  if (!p.tipo) throw new Error('Tipo é obrigatório');",
  "  if (!p.valor || isNaN(p.valor)) throw new Error('Valor inválido');",
  "  const sh = fc2_aba_(FC2_CONFIG.ABAS.LANC);",
  "  const mapa = fc2_resolverMapaColunas_(sh);",
  "  const lastCol = sh.getLastColumn();",
